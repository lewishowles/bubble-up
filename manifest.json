{
	"manifest_version": 3,
	"name": "Bubble Up",
	"description": "Simplify some of the repetitive workflows in the Bubble.io editor.",
	"version": "0.1.0",

	"content_scripts": [
		{
			"matches": ["https://bubble.io/page?*"],
			"js": ["content/index.js"],
			"run_at": "document_idle"
		}
	],

	"web_accessible_resources": [
		{
			"resources": [
				"content/app.js",
				"content/**/*.js"
			],
			"matches": [
				"https://bubble.io/*"
			]
		}
	]
}
