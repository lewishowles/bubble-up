{
	"manifest_version": 3,
	"name": "Bubble Up",
	"description": "Simplify some of the repetitive workflows in the Bubble.io editor.",
	"version": "0.1.1",

	"browser_specific_settings": {
		"gecko": {
			"id": "bubble-up@howles.dev",
			"strict_min_version": "140.0",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},

	"content_scripts": [
		{
			"matches": ["https://bubble.io/page?*"],
			"js": ["content/index.js"],
			"run_at": "document_idle"
		}
	],

	"web_accessible_resources": [
		{
			"resources": [
				"content/app.js",
				"content/features/layout.js",
				"content/features/sizing.js",
				"content/features/ui.js",
				"content/helpers/bubble/interaction.js",
				"content/helpers/bubble/selectors.js",
				"content/helpers/dom/interaction.js",
				"content/helpers/dom/query.js",
				"content/helpers/utilities/log.js",
				"content/helpers/utilities/wait.js"
			],
			"matches": [
				"https://bubble.io/*"
			]
		}
	]
}
